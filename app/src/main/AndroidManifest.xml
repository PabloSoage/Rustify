<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="ForegroundServicePermission">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" tools:ignore="all" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/rustify"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/rustify_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Rustify">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|locale|layoutDirection"
            android:theme="@style/Theme.Rustify">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link para URLs de Spotify (E20: todos los tipos + intl-) -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:host="open.spotify.com" />
                <data android:pathPrefix="/track/" />
                <data android:pathPrefix="/album/" />
                <data android:pathPrefix="/playlist/" />
                <data android:pathPrefix="/artist/" />
                <data android:pathPrefix="/intl-" />
            </intent-filter>

            <!-- F1.A: Wrapper Rustify VERIFICABLE (App Link). El host es un PLACEHOLDER build-time
                 y DEBE ser un dominio propio del usuario/proyecto que aloje
                 https://<host>/.well-known/assetlinks.json con el fingerprint SHA-256 de la firma.
                 Sin ese JSON, autoVerify simplemente NO verifica (se comporta como web link manual).
                 El host es fijo en compilación (no runtime); considerar manifestPlaceholders. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="rustify.example.com" android:pathPrefix="/r" />
            </intent-filter>

            <!-- F1.A: Fallback SIN verificación fuerte (cualquier app puede reclamar el scheme).
                 Registra rustify:// para que el branch de extractDeepLink sea alcanzable. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="rustify" />
            </intent-filter>

            <!-- Share Target: intercept shared Spotify links from other apps -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <service
            android:name=".player.RustifyForegroundService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="true"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService"/>
            </intent-filter>
        </service>

    </application>

</manifest>