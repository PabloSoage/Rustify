<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="ForegroundServicePermission">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" tools:ignore="all" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- DJ v2.8: voice control (speech recognition). Requested at runtime. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- E99: travel playlist — current location to compute the route/ETA. Requested at runtime. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- E99+: resolver short links de Google Maps (maps.app.goo.gl) → requiere network. -->
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/rustify"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/rustify_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Rustify">
        <!-- E96 — Android Auto: declare the media browse capability. -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|locale|layoutDirection"
            android:theme="@style/Theme.Rustify">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link para URLs de Spotify (E20: todos los tipos + intl-) -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:host="open.spotify.com" />
                <data android:pathPrefix="/track/" />
                <data android:pathPrefix="/album/" />
                <data android:pathPrefix="/playlist/" />
                <data android:pathPrefix="/artist/" />
                <data android:pathPrefix="/intl-" />
            </intent-filter>

            <!-- E40: YouTube Music deep links -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- E40: scope to real YTM entities so we don't hijack every music.youtube.com URL. -->
                <data android:scheme="https" android:host="music.youtube.com" android:pathPrefix="/watch" />
                <data android:scheme="https" android:host="music.youtube.com" android:pathPrefix="/playlist" />
                <data android:scheme="https" android:host="music.youtube.com" android:pathPrefix="/browse" />
                <data android:scheme="https" android:host="music.youtube.com" android:pathPrefix="/channel" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="youtu.be" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="www.youtube.com" android:pathPrefix="/watch" />
            </intent-filter>

            <!-- F1.A: Wrappers Rustify VERIFICABLES (App Links).
                 Cada host DEBE alojar https://<host>/.well-known/assetlinks.json con el fingerprint
                 SHA-256 de la firma. Sin ese JSON, autoVerify simplemente NO verifica.
                 El host es fijo en compilación (no runtime).
                 Hosts sincronizados con util/AppLinksHosts.kt — añadir/quitar allí y aquí. -->

            <!-- rustify-music.github.io (organización del proyecto) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="rustify-music.github.io" android:pathPrefix="/r" />
            </intent-filter>

            <!-- pablosoage.github.io (dominio personal del maintainer) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="pablosoage.github.io" android:pathPrefix="/r" />
            </intent-filter>

            <!-- Placeholder de referencia (NO verifica: rustify.example.com no existe) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="rustify.example.com" android:pathPrefix="/r" />
            </intent-filter>

            <!-- F1.A: Fallback SIN verificación fuerte (cualquier app puede reclamar el scheme).
                 Registra rustify:// para que el branch de extractDeepLink sea alcanzable. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="rustify" />
            </intent-filter>

            <!-- Share Target: intercept shared Spotify links from other apps -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <!-- E99+: intercept geo: links (Android standard) and Google Maps URLs -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="geo" />
            </intent-filter>
        </activity>

        <service
            android:name=".player.RustifyForegroundService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="true"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaLibraryService"/>
                <action android:name="androidx.media3.session.MediaSessionService"/>
                <!-- E96 — Android Auto / legacy media browsers connect via MediaBrowserService. -->
                <action android:name="android.media.browse.MediaBrowserService"/>
            </intent-filter>
        </service>

        <!-- E50 (B) — AppAuth OAuth redirect. Uses an HTTPS App Link on our already-verified
             domain (same host as the /r/ share links) so the OAuth client is NOT tied to the APK
             signing certificate; one client works on any build. Requires an assetlinks.json on the
             host and https://rustify-music.github.io/oauth2redirect to exist (a blank page is fine).
             tools:node="replace" overrides AppAuth's default custom-scheme intent-filter. -->
        <activity
            android:name="net.openid.appauth.RedirectUriReceiverActivity"
            android:exported="true"
            tools:node="replace">
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                    android:host="rustify-music.github.io"
                    android:pathPrefix="/oauth2redirect" />
            </intent-filter>
        </activity>

    </application>

</manifest>